{
  "$schema": "https://raw.githubusercontent.com/DavidAnson/markdownlint-cli2/main/schema/markdownlint-cli2-config-schema.json",
  "config": {
    "default": true,
    "MD013": false,
    "MD033": {
      "allowed_elements": ["img", "details", "summary"]
    },
    "MD041": false
  },
  "gitignore": true,
  "ignores": [
    "IMPLEMENTATION_GOAL.md",
    "TODO.md",
    "prompt-*.md"
  ],
  "noProgress": true
}
