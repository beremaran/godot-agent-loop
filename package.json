{
  "name": "@tugcantopaloglu/godot-mcp",
  "version": "3.0.0",
  "description": "MCP server for full Godot 4.x engine control with 157 tools for AI-driven game development",
  "keywords": [
    "godot",
    "mcp",
    "ai",
    "claude",
    "cline",
    "game-engine",
    "gdscript",
    "runtime",
    "model-context-protocol"
  ],
  "homepage": "https://github.com/tugcantopaloglu/godot-mcp",
  "bugs": {
    "url": "https://github.com/tugcantopaloglu/godot-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tugcantopaloglu/godot-mcp.git"
  },
  "mcpName": "io.github.tugcantopaloglu/godot-mcp",
  "license": "MIT",
  "author": "Tugcan Topaloglu",
  "contributors": [
    "Solomon Elias <solomon@sippy.ai> (https://github.com/Coding-Solo)"
  ],
  "type": "module",
  "bin": {
    "godot-mcp": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && node scripts/build.js",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
