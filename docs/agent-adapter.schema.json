{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/beremaran/godot-agent-loop/blob/main/docs/agent-adapter.schema.json",
  "title": "Godot Agent Loop adapter manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "displayName", "version", "description", "package", "mcp", "skills", "defaultPrompts", "clients"],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "displayName": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "description": { "type": "string", "minLength": 1 },
    "package": { "type": "string", "minLength": 1 },
    "mcp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "environment", "canonicalSurface", "surfaceAliases", "catalogTool", "callTool", "deprecatedCompatibilityTool", "compatibilityThrough"],
      "properties": {
        "command": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "environment": { "type": "object", "additionalProperties": { "type": "string" } },
        "canonicalSurface": { "const": "core" },
        "surfaceAliases": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "catalogTool": { "const": "godot_catalog" },
        "callTool": { "const": "godot_call" },
        "deprecatedCompatibilityTool": { "const": "godot_tools" },
        "compatibilityThrough": { "type": "string", "minLength": 1 }
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description", "interface", "toolContract"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "description": { "type": "string", "minLength": 1 },
          "interface": {
            "type": "object",
            "additionalProperties": false,
            "required": ["displayName", "shortDescription", "defaultPrompt"],
            "properties": {
              "displayName": { "type": "string", "minLength": 1 },
              "shortDescription": { "type": "string", "minLength": 25, "maxLength": 64 },
              "defaultPrompt": { "type": "string", "minLength": 1 }
            }
          },
          "toolContract": {
            "type": "object",
            "additionalProperties": false,
            "required": ["direct", "hidden", "privilegedGroups", "effectScopes"],
            "properties": {
              "direct": { "$ref": "#/$defs/toolNames" },
              "hidden": { "$ref": "#/$defs/toolNames" },
              "privilegedGroups": {
                "type": "array",
                "uniqueItems": true,
                "items": { "enum": ["reflection", "code-execution", "network"] }
              },
              "effectScopes": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": { "enum": ["read-only", "project-persistent", "runtime-ephemeral", "process", "external-open-world"] }
              }
            }
          }
        }
      }
    },
    "defaultPrompts": { "type": "array", "minItems": 1, "maxItems": 3, "items": { "type": "string", "minLength": 1 } },
    "clients": { "type": "object", "required": ["claudeCode", "codex", "openCode", "pi"] }
  },
  "$defs": {
    "toolNames": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
    }
  }
}
