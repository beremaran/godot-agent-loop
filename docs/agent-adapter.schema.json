{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/beremaran/godot-agent-loop/blob/main/docs/agent-adapter.schema.json",
  "title": "Godot Agent Loop adapter manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "displayName", "version", "description", "package", "mcp", "skills", "defaultPrompts", "clients"],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "displayName": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "description": { "type": "string", "minLength": 1 },
    "package": { "type": "string", "minLength": 1 },
    "mcp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "environment", "defaultToolCount", "discoveryTool"],
      "properties": {
        "command": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "environment": { "type": "object", "additionalProperties": { "type": "string" } },
        "defaultToolCount": { "type": "integer", "minimum": 1 },
        "discoveryTool": { "type": "string", "minLength": 1 }
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "defaultPrompts": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "clients": { "type": "object", "required": ["claudeCode", "codex", "openCode", "pi"] }
  }
}
